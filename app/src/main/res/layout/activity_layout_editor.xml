<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:tag="accent"
            android:text="Edit Layout"
            android:textColor="@color/textPrimary"
            android:textSize="17sp" />

        <Button
            android:id="@+id/templates"
            style="@style/ChipButton"
            android:text="Templates" />

        <Button
            android:id="@+id/addApp"
            style="@style/ChipButton"
            android:text="+ Free tile" />

        <Button
            android:id="@+id/clearAll"
            style="@style/ChipButton"
            android:text="Clear" />

        <Button
            android:id="@+id/save"
            style="@style/ChipButton"
            android:text="Save" />

        <Button
            android:id="@+id/close"
            style="@style/ChipButton"
            android:text="Close" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="6dp"
        android:text="Pick a Template, then tap a + slot to drop in an app, camera, web dashboard or gauge. Drag to nudge, corner grip to resize. Save = your default layout that auto-loads on start."
        android:textColor="@color/textDim"
        android:textSize="11sp" />

    <FrameLayout
        android:id="@+id/previewOuter"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0A0A0C">

        <FrameLayout
            android:id="@+id/previewInner"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:background="#12FFFFFF" />
    </FrameLayout>
</LinearLayout>
