<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/overlay_bg"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/handle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingLeft="12dp"
        android:paddingTop="7dp"
        android:paddingRight="12dp"
        android:paddingBottom="7dp"
        android:text="≡  DWM"
        android:textColor="#3E6AE1"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/expanded"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="200dp"
        android:orientation="vertical"
        android:paddingLeft="6dp"
        android:paddingTop="6dp"
        android:paddingRight="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:text="--:--:--"
            android:textColor="#F2F2F2"
            android:textSize="20sp" />

        <LinearLayout
            android:id="@+id/favRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="6dp" />

        <Button
            android:id="@+id/btnOpenCockpit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open Cockpit" />

        <Button
            android:id="@+id/btnOverlays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toggle overlays" />

        <Button
            android:id="@+id/btnRaise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Raise windows" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCollapse"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Collapse" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stop" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
